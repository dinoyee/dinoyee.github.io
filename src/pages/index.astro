---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="首頁" description="DinoYee 的個人部落格，分享技術筆記與心得">
  <section class="text-center py-16">
    <h1 class="text-4xl md:text-5xl font-bold mb-4">DinoYee 的部落格</h1>
    <p class="text-lg text-gray-600 mb-8">分享技術筆記、開發心得與學習歷程</p>
    <a
      href="/blog"
      class="inline-block bg-blue-600 text-white px-6 py-3 rounded-lg font-medium hover:bg-blue-700 no-underline transition-colors"
    >
      查看所有文章
    </a>
  </section>
</BaseLayout>
