---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="首頁" description="DinoYee 的個人部落格，分享技術筆記與心得">
  <div class="text-center space-y-6 max-w-2xl">
    <h1 class="text-hero">DinoYee 的部落格</h1>
    <p class="text-lead-airy text-apple-ink-muted-80 mx-auto">
      分享技術筆記、開發心得與學習歷程。
    </p>
    <div class="pt-4">
      <a href="/blog" class="apple-btn-primary no-underline">
        查看所有文章
      </a>
    </div>
  </div>
</BaseLayout>
