---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="部落格" description="DinoYee 的所有部落格文章">
  <header class="text-center space-y-4 mb-16">
    <h1 class="text-display-xl text-expo-ink">部落格</h1>
    <p class="text-body-md text-expo-body">所有文章</p>
  </header>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 w-full max-w-5xl">
    {posts.map(post => (
      <article class="expo-card expo-card-hover flex flex-col h-full">
        <div class="flex-1">
          <div class="flex items-center gap-2 mb-4">
            <time class="text-caption text-expo-muted">
              {post.data.date.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            {post.data.tags.slice(0, 2).map(tag => (
              <span key={tag} class="expo-badge">{tag}</span>
            ))}
          </div>
          <h2 class="text-title-md text-expo-ink leading-tight mb-2">
            <a href={`/blog/${post.slug}`} class="no-underline hover:text-expo-text-link">
              {post.data.title}
            </a>
          </h2>
          <p class="text-body-sm text-expo-body line-clamp-2">{post.data.description}</p>
        </div>
        <div class="mt-6 pt-4 border-t border-expo-hairline">
          <a href={`/blog/${post.slug}`} class="text-expo-text-link no-underline text-button font-medium hover:underline">
            閱讀更多 &rarr;
          </a>
        </div>
      </article>
    ))}
  </div>
</BaseLayout>
