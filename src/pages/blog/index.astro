---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="部落格" description="DinoYee 的所有文章">
  <h1 class="text-3xl font-bold mb-8">部落格</h1>

  {posts.length === 0 ? (
    <p class="text-gray-500">尚無文章，敬請期待。</p>
  ) : (
    <div class="space-y-8">
      {posts.map((post) => (
        <article class="border-b border-gray-200 pb-8 last:border-0">
          <a href={`/blog/${post.id.replace(/\.(md|mdx)$/, '')}`} class="block no-underline group">
            <h2 class="text-xl font-semibold mb-2 group-hover:text-blue-600 transition-colors">
              {post.data.title}
            </h2>
            <time class="text-sm text-gray-500 mb-2 block">
              {post.data.date.toLocaleDateString('zh-TW', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
            <p class="text-gray-600 mb-3">{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {post.data.tags.map((tag: string) => (
                  <span class="bg-gray-100 text-gray-600 px-2 py-1 rounded text-xs">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </a>
        </article>
      ))}
    </div>
  )}
</BaseLayout>
