---
import { SearchTrigger } from '@/components/Search';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A personal blog by DinoYee' } = Astro.props;
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | DinoYee Blog</title>
  </head>
  <body class="bg-expo-canvas text-expo-body font-sans">
    <nav class="bg-expo-canvas border-b border-expo-hairline h-16 px-6 flex items-center justify-between sticky top-0 z-50">
      <a href="/" class="text-expo-ink font-semibold text-nav-link hover:text-expo-text-link transition-colors no-underline">
        DinoYee
      </a>
      <div class="flex items-center gap-6">
        <a href="/" class="nav-link">首頁</a>
        <a href="/blog" class="nav-link">部落格</a>
        <a href="/tags" class="nav-link">分類</a>
        <SearchTrigger client:only="react" />
      </div>
    </nav>

    <main class="min-h-screen flex flex-col items-center py-section px-4">
      <slot />
    </main>

    <footer class="bg-expo-canvas border-t border-expo-hairline py-section px-6">
      <div class="max-w-5xl mx-auto text-center text-body-sm text-expo-muted">
        © {new Date().getFullYear()} DinoYee. All rights reserved.
      </div>
    </footer>
  </body>
</html>
