---
import '@/styles/global.css';
import { SearchTrigger } from '@/components/Search';
import { ThemeToggle } from '@/components/ThemeToggle';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A personal blog by DinoYee' } = Astro.props;
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | DinoYee Blog</title>
    <script is:inline>
      const theme = localStorage.getItem('theme');
      if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
  </head>
  <body class="bg-expo-canvas text-expo-body font-sans dark:bg-expo-surface-dark dark:text-expo-on-dark-soft transition-colors duration-200">
    <nav class="bg-expo-canvas border-b border-expo-hairline h-16 px-6 flex items-center justify-between sticky top-0 z-50 dark:bg-expo-surface-dark dark:border-expo-surface-dark-elevated transition-colors duration-200">
      <a href="/" class="text-expo-ink font-semibold text-nav-link hover:text-expo-text-link transition-colors no-underline dark:text-expo-on-dark dark:hover:text-expo-accent-link-bright">
        DinoYee
      </a>
      <div class="flex items-center gap-4">
        <a href="/" class="nav-link dark:text-expo-on-dark-soft dark:hover:text-expo-on-dark">首頁</a>
        <a href="/blog" class="nav-link dark:text-expo-on-dark-soft dark:hover:text-expo-on-dark">部落格</a>
        <a href="/tags" class="nav-link dark:text-expo-on-dark-soft dark:hover:text-expo-on-dark">分類</a>
        <SearchTrigger client:only="react" />
        <a
          href="https://github.com/dinoyee"
          target="_blank"
          rel="noopener noreferrer"
          class="w-9 h-9 flex items-center justify-center rounded-full hover:bg-expo-surface-strong transition-colors text-expo-ink dark:text-expo-on-dark"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
            class="w-5 h-5"
          >
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
          </svg>
        </a>
        <ThemeToggle client:only="react" />
      </div>
    </nav>

    <main class="min-h-screen flex flex-col items-center py-section px-4">
      <slot />
    </main>

    <footer class="bg-expo-canvas border-t border-expo-hairline py-section px-6 dark:bg-expo-surface-dark dark:border-expo-surface-dark-elevated transition-colors duration-200">
      <div class="max-w-5xl mx-auto text-center text-body-sm text-expo-muted dark:text-expo-on-dark-soft">
        © {new Date().getFullYear()} DinoYee. All rights reserved.
      </div>
    </footer>

    <script is:inline>
      (function() {
        function initCodeBlocks() {
          document.querySelectorAll('pre').forEach(function(pre) {
            if (pre.querySelector('.code-header')) return;
            
            var code = pre.querySelector('code');
            var lang = 'CODE';

            // Collect all classes from pre and code
            var classes = [];
            if (pre.className) classes = pre.className.split(/\s+/);
            if (code && code.className) classes = classes.concat(code.className.split(/\s+/));

            // 1. Check for data-language attribute (common in Shiki/Astro)
            if (pre.dataset.language) {
              lang = pre.dataset.language;
            } 
            // 2. Check for classes like language-xxx, lang-xxx, astro-code-xxx
            else {
              var match = classes.find(function(cls) {
                return cls.startsWith('language-') || 
                       cls.startsWith('lang-') || 
                       cls.startsWith('astro-code-');
              });
              
              if (match) {
                lang = match.replace('language-', '').replace('lang-', '').replace('astro-code-', '');
              }
            }

            // Clean up and format
            lang = lang.replace(/[-_]/g, ' ').toUpperCase();

            var header = document.createElement('div');
            header.className = 'code-header';
            header.innerHTML = '<span class="lang">' + lang + '</span>' +
                               '<button class="copy-btn" aria-label="Copy code"><span>Copy</span></button>';
            
            pre.insertBefore(header, pre.firstChild);

            var btn = header.querySelector('.copy-btn');
            btn.addEventListener('click', function() {
              if (navigator.clipboard) {
                var textToCopy = code ? code.innerText : pre.innerText;
                navigator.clipboard.writeText(textToCopy).then(function() {
                  var span = btn.querySelector('span');
                  var original = span.textContent;
                  span.textContent = 'Copied!';
                  setTimeout(function() {
                    span.textContent = original;
                  }, 2000);
                }).catch(function(err) {
                  console.error('Failed to copy: ', err);
                });
              }
            });
          });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initCodeBlocks);
        } else {
          initCodeBlocks();
        }
      })();
    </script>
  </body>
</html>
