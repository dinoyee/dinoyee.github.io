---
import { SearchTrigger } from '@/components/Search';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A personal blog by DinoYee' } = Astro.props;
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | DinoYee Blog</title>
  </head>
  <body class="bg-apple-canvas text-apple-ink">
    <nav class="bg-apple-surface-black h-11 px-6 flex items-center justify-between sticky top-0 z-50">
      <a href="/" class="text-white font-semibold text-nav hover:text-apple-blue-dark transition-colors no-underline">
        DinoYee
      </a>
      <div class="flex items-center gap-6">
        <a href="/" class="text-white text-nav hover:text-apple-blue-dark transition-colors no-underline">首頁</a>
        <a href="/blog" class="text-white text-nav hover:text-apple-blue-dark transition-colors no-underline">部落格</a>
        <SearchTrigger client:only="react" />
      </div>
    </nav>

    <main class="min-h-screen flex flex-col items-center py-section px-4">
      <slot />
    </main>

    <footer class="bg-apple-parchment py-section px-6 border-t border-apple-hairline">
      <div class="max-w-3xl mx-auto text-center text-fine-print text-apple-ink-muted-48">
        © {new Date().getFullYear()} DinoYee. All rights reserved.
      </div>
    </footer>
  </body>
</html>
